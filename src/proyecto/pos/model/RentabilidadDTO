package proyecto.pos.model;

public class RentabilidadDTO {
    private int platoId;
    private String nombrePlato;
    private String categoria;
    private double costoInsumos;
    private double precioVenta;
    private double margenPorcentaje;
    private String estado;

    // Constructor, Getters y Setters
    public RentabilidadDTO(int platoId, String nombrePlato, String categoria, double costoInsumos, double precioVenta, double margenPorcentaje, String estado) {
        this.platoId = platoId;
        this.nombrePlato = nombrePlato;
        this.categoria = categoria;
        this.costoInsumos = costoInsumos;
        this.precioVenta = precioVenta;
        this.margenPorcentaje = margenPorcentaje;
        this.estado = estado;
    }

    public int getPlatoId() { return platoId; }
    public String getNombrePlato() { return nombrePlato; }
    public String getCategoria() { return categoria; }
    public double getCostoInsumos() { return costoInsumos; }
    public double getPrecioVenta() { return precioVenta; }
    public double getMargenPorcentaje() { return margenPorcentaje; }
    public String getEstado() { return estado; }
    
    public void setPrecioVenta(double precioVenta) { this.precioVenta = precioVenta; }
    public void setMargenPorcentaje(double margenPorcentaje) { this.margenPorcentaje = margenPorcentaje; }
    public void setEstado(String estado) { this.estado = estado; }
}
